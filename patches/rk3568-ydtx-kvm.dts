			regulator-state-mem {
				regulator-off-in-suspend;
			};
		};

		pmic@20 {
			compatible = "rockchip,rk809";
			reg = <0x20>;
			interrupt-parent = <0x37>;
			interrupts = <0x03 0x08>;
			pinctrl-names = "default", "pmic-sleep", "pmic-power-off", "pmic-reset";
			pinctrl-0 = <0x38>;
			pinctrl-1 = <0x39 0x3a>;
			pinctrl-2 = <0x3b 0x3c>;
			pinctrl-3 = <0x3b 0x3d>;
