			clock-output-names = "rk808-clkout1", "rk808-clkout2";
			pmic-reset-func = <0x00>;
			not-save-power-en = <0x01>;
			vcc1-supply = <0x3e>;
			vcc2-supply = <0x3e>;
			vcc3-supply = <0x3e>;
			vcc4-supply = <0x3e>;
			vcc5-supply = <0x3e>;
			vcc6-supply = <0x3e>;
			vcc7-supply = <0x3e>;
			vcc8-supply = <0x3e>;
			vcc9-supply = <0x3e>;
