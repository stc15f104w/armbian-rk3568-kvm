			route-edp {
				status = "disabled";
				logo,uboot = "logo.bmp";
				logo,kernel = "logo_kernel.bmp";
				logo,mode = "center";
				charge_logo,mode = "center";
				connect = <0x16>;
				phandle = <0x150>;
			};

			route-hdmi {
				cubic_lut,offset = <0x00>;
				overscan,bottom_margin = <0x64>;
				overscan,top_margin = <0x64>;
				overscan,right_margin = <0x64>;
				overscan,left_margin = <0x64>;
				video,aspect_ratio = <0x00>;
				video,flags = <0x00>;
				video,vrefresh = <0x00>;
				video,crtc_vsync_end = <0x00>;
				video,crtc_hsync_end = <0x00>;
				video,vdisplay = <0x00>;
				video,hdisplay = <0x00>;
				video,clock = <0x00>;
				logo,ymirror = <0x00>;
				logo,bpp = <0x18>;
				logo,height = <0x10e>;
				logo,width = <0x28e>;
				logo,offset = <0x186000>;
				status = "okay";
				logo,uboot = "logo.bmp";
				logo,kernel = "logo_kernel.bmp";
				logo,mode = "center";
				charge_logo,mode = "center";
				connect = <0x17>;
				phandle = <0x151>;
			};

			route-lvds {
				status = "disabled";
				logo,uboot = "logo.bmp";
				logo,kernel = "logo_kernel.bmp";
				logo,mode = "center";
				charge_logo,mode = "center";
				connect = <0x18>;
