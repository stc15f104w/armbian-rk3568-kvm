		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		vin-supply = <0x36>;
		phandle = <0x206>;
	};

	vcc-camera-regulator {
		compatible = "regulator-fixed";
		status = "okay";
		gpio = <0x37 0x08 0x00>;
		pinctrl-names = "default";
		pinctrl-0 = <0x146>;
		regulator-name = "vcc_camera";
		enable-active-high;
		regulator-always-on;
		regulator-boot-on;
		phandle = <0x207>;
	};

	vcc-hdmi-pwren {
		compatible = "regulator-fixed";
		pinctrl-names = "default";
		pinctrl-0 = <0x147>;
		regulator-name = "vcc-hdmi";
		regulator-always-on;
		phandle = <0x208>;
	};

	xgpio_buz {
		status = "okay";
		compatible = "lhd,xgpio";
		pinctrl-names = "default";
		pinctrl-0 = <0x148>;
