		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <0x1b7740>;
		regulator-max-microvolt = <0x1b7740>;
		vin-supply = <0x3e>;
		phandle = <0x203>;
	};

	vcc3v3-minipcie {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_minipcie";
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		enable-active-high;
		gpio = <0x37 0x16 0x00>;
		vin-supply = <0x139>;
		phandle = <0x145>;
	};

	vcc3v9-minipcie {
		compatible = "regulator-fixed";
