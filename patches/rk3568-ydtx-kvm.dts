	};

	wireless-wlan {
		compatible = "wlan-platdata";
		rockchip,grf = <0x33>;
		wifi_chip_type = "ap6275s";
		pinctrl-names = "default";
		pinctrl-0 = <0x140>;
		WIFI,host_wake_irq = <0x80 0x1c 0x00>;
		status = "disabled";
		phandle = <0x1fb>;
	};

	wireless-bluetooth {
		compatible = "bluetooth-platdata";
		clocks = <0x13e>;
		clock-names = "ext_clock";
		uart_rts_gpios = <0x97 0x09 0x01>;
		pinctrl-names = "default", "rts_gpio";
		pinctrl-0 = <0x141 0x142>;
		pinctrl-1 = <0x143>;
		BT,reset_gpio = <0xe4 0x10 0x00>;
		status = "disabled";
		phandle = <0x1fc>;
	};

	test-power {
		status = "okay";
	};

	chosen {
		bootargs = "storagemedia=emmc androidboot.storagemedia=emmc androidboot.mode=normal  androidboot.verifiedbootstate=orange rw rootwait earlycon=uart8250,mmio32,0xfe660000 console=ttyFIQ0 root=PARTUUID=614e0000-0000";
		phandle = <0x1fd>;
	};

	fiq-debugger {
		compatible = "rockchip,fiq-debugger";
		rockchip,serial-id = <0x02>;
		rockchip,wake-irq = <0x00>;
		rockchip,irq-mode-enable = <0x01>;
		rockchip,baudrate = <0x16e360>;
		interrupts = <0x00 0xfc 0x08>;
		pinctrl-names = "default";
		pinctrl-0 = <0xfa>;
		status = "okay";
	};

	debug@fd904000 {
		compatible = "rockchip,debug";
		reg = <0x00 0xfd904000 0x00 0x1000 0x00 0xfd905000 0x00 0x1000 0x00 0xfd906000 0x00 0x1000 0x00 0xfd907000 0x00 0x1000>;
		phandle = <0x1fe>;
	};

	cspmu@fd90c000 {
		compatible = "rockchip,cspmu";
		reg = <0x00 0xfd90c000 0x00 0x1000 0x00 0xfd90d000 0x00 0x1000 0x00 0xfd90e000 0x00 0x1000 0x00 0xfd90f000 0x00 0x1000>;
		phandle = <0x1ff>;
	};

	external-camera-clock {
		compatible = "fixed-clock";
		clock-frequency = <0x16e3600>;
		clock-output-names = "CLK_CAMERA_24MHZ";
		#clock-cells = <0x00>;
		phandle = <0xe3>;
	};

	rk-headset {
		compatible = "rockchip_headset";
		headset_gpio = <0x80 0x11 0x00>;
		pinctrl-names = "default";
		pinctrl-0 = <0x144>;
		io-channels = <0x12b 0x02>;
		phandle = <0x200>;
	};

	vcc2v5-ddr {
		compatible = "regulator-fixed";
		regulator-name = "vcc2v5-sys";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <0x2625a0>;
		regulator-max-microvolt = <0x2625a0>;
		vin-supply = <0x3e>;
		phandle = <0x201>;
	};

