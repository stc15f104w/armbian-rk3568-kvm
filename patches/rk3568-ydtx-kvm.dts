		scmi {
			compatible = "arm,scmi-smc";
			shmem = <0x1a>;
			arm,smc-id = <0x82000010>;
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			phandle = <0x155>;

			protocol@14 {
				reg = <0x14>;
				#clock-cells = <0x01>;
